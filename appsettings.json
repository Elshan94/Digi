{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Error",
        "DigitalDepositAccountService.Helpers.RequestResponseLogger": "Warning",
        "Elastic.Apm": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "/microservices/logs/DigitalSalaryService/Log.txt",
          "outputTemplate": "{Timestamp:o} {Level:u3} {ProviderName} {Message:lj}{NewLine}{Exception}",
          "rollingInterval": "Day",
          "retainedFileCountLimit": null,
          "shared": true
        }
      }
    ]
  },
  "ElasticConfiguration": {
    "Uri": "$ELK_URL",
    "Env": "$ELK_ENV"
  },
  "ElasticApm": {
    "ServerUrls": "$ELK_APM_URL"
  },
  "SimaConfig": {
    "BaseUrl": "https://testrecording-api.sima.az/",
    "Service": "accessbank",
    "Key": "Ad5g5Homfkiive/JoxaL9DWRzdS1Bwb9VWznrye2ZPU=",
    "CallbackUrl": "https://digitalsalaryservice.svc-test.accessbank.az/api/callback"
  },
  "SimaSignerClientConfig": {
    "BaseUrl": "$SIMA_SIGNER_FOR_DS_URL",
    "AssignersPriorities": [
      {
        "AssignerPinNumber": "00P32HN",
        "Priority": 1
      },
      {
        "AssignerPinNumber": "15WUSBY",
        "Priority": 2
      }
    ]
  },
  "IbConfig": {
    "BaseUrl": "https://myaccess-t.testaccessbank.local/ibs/"
  },
  "DigitalSalaryDbContext": {
    "DataSource": "$MCR_DB_DATASOURCE",
    "InitialCatalog": "DigitalSalaryDB",
    "UserID": "$MCR_DB_USER",
    "Password": "$MCR_DB_PSWD"
  },
  "RedisConnection": "$REDIS_CONNECTION",
  "MinioClientConfig": {
    "Endpoint": "$MINIO_ENDPOINT",
    "AccessKey": "$MINIO_ACCESS_KEY",
    "SecretKey": "$MINIO_SECRET_KEY",
    "BucketName": "digital-salary-files",
    "Region": "$MINIO_REGION"
  },
  "T24Config": {
    "BaseUrl": "$CBS_URL_TWS_GS",
    "UserName": "$CBS_ESBGEN_USER",
    "Password": "$CBS_ESBGEN_PSWD",
    "UserNameAuth": "$CBS_ESBGEN_AUTH_USER",
    "PasswordAuth": "$CBS_ESBGEN_AUTH_PSWD",
    "BranchId": "AZ0010001"
  },
  "JasperConfig": {
    "BaseUrl": "$JASPER_SERVER_URL",
    "SalaryAgreementPath": "?_flowId=viewReportFlow&standAlone=true&_flowId=viewReportFlow&ParentFolderUri=%2FReports&reportUnit=%2FReports%2FTermDepositOpenIndDig&FileName={0}&output=pdf",
    "JasperViewUrl": "$JASPER_VIEW_URL"
  },
  "KycConfig": {
    "BaseUrl": "https://kycprocessingservice.svc-test.accessbank.az/",
    "ApiKey": "$APIKEY_IBS"
  },
  "FatcaConfig": {
    "BaseUrl": "https://fatcaprocessingservice.svc-test.accessbank.az/",
    "ApiKey": "$APIKEY_IBS"
  }
}
